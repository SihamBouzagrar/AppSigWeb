@model ReservationHotel.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Créer un compte";
}

<style>
    body {
        background: #0f172a;
    }

    .auth-container {
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-card {
        width: 100%;
        max-width: 480px;
        background: #111827;
        border-radius: 16px;
        padding: 32px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        color: white;
    }

    .auth-title {
        text-align: center;
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 25px;
        color: #f9fafb;
    }

    label {
        color: #d1d5db;
        font-size: 14px;
        margin-bottom: 5px;
    }

    .form-control {
        background: #1f2937;
        border: 1px solid #374151;
        color: white;
        border-radius: 10px;
        padding: 10px;
    }

    .form-control:focus {
        border-color: #f59e0b;
        box-shadow: none;
        background: #111827;
        color: white;
    }

    .btn-register {
        width: 100%;
        background: #f59e0b;
        border: none;
        padding: 12px;
        border-radius: 10px;
        font-weight: 600;
        color: #111827;
        transition: 0.3s;
    }

    .btn-register:hover {
        background: #d97706;
    }

    .auth-link {
        text-align: center;
        margin-top: 15px;
        color: #9ca3af;
    }

    .auth-link a {
        color: #f59e0b;
        text-decoration: none;
    }

    .auth-link a:hover {
        text-decoration: underline;
    }

    .text-danger {
        font-size: 13px;
    }
</style>

<div class="auth-container">
    <div class="auth-card">

        <div class="auth-title">Créer un compte</div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-register">S'inscrire</button>
        </form>

        <div class="auth-link">
            Déjà un compte ?
            <a asp-action="Login">Se connecter</a>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}